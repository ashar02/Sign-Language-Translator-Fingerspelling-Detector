# Sign Language Translator - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED / PROVIDER KEYS
# =============================================================================

# Text correction provider: groq (free, default) | openai | none
CORRECTION_PROVIDER=groq

# Groq API Key (free): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Stronger default for aggressive word guessing (fallback: llama-3.1-8b-instant)
GROQ_MODEL=llama-3.3-70b-versatile
# 0.0 = conservative, 0.7 = aggressive guesses (default)
CORRECTION_TEMPERATURE=0.7

# OpenAI (only needed when CORRECTION_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Speak provider: browser (free, default) or elevenlabs
SPEAK_PROVIDER=browser

# Camera source: browser (client webcam, for remote/staging) or server (local /dev/video0)
CAMERA_SOURCE=browser

# Inference mode: client (MediaPipe+RF in browser, fast) or server (upload frames)
INFERENCE_MODE=client

# ElevenLabs (only needed when SPEAK_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_preferred_voice_id_here

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Server / traffic
# HOST bind address (0.0.0.0 = all interfaces)
HOST=0.0.0.0
# Listen port
PORT=5000
# Traffic mode: http (default) or https
TRAFFIC=http
# Required when TRAFFIC=https (paths relative to project root or absolute)
# Example:
#   SSL_CERT_FILE=certs/cert.pem
#   SSL_KEY_FILE=certs/key.pem
SSL_CERT_FILE=
SSL_KEY_FILE=

# UI visibility (true/false; default show)
SHOW_HEADER=true
SHOW_FOOTER=true
SHOW_SIGN_TO_TEXT=true
SHOW_TEXT_TO_SIGN=true

# Detection Settings
# Minimum confidence for hand detection (0.0 - 1.0)
MIN_DETECTION_CONFIDENCE=0.3

# Stability Settings
# Number of consecutive identical predictions required
STABILITY_THRESHOLD=5

# Time window for stability check (seconds)
STABILITY_TIME_WINDOW=1.0

# Delay before accepting new character (seconds)
STABILIZATION_DELAY=2.0
